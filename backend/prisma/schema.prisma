generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                      String                 @id @default(uuid())
  name                    String
  businessType            BusinessType
  gstin                   String?                @unique
  pan                     String?
  phone                   String
  email                   String                 @unique
  address                 String?
  city                    String?
  state                   String?
  pincode                 String?
  logoUrl                 String?
  syllabrixId             String?                @unique
  plan                    PlanType               @default(STARTER)
  isActive                Boolean                @default(true)
  modules                 Json
  receiptConfig           Json?
  automationConfig        Json?
  currency                String                 @default("INR")
  locale                  String                 @default("en-IN")
  timezone                String                 @default("Asia/Kolkata")
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  appointments            Appointment[]
  categories              Category[]
  customers               Customer[]
  expenses                Expense[]
  feeRecords              FeeRecord[]
  invoices                Invoice[]
  leaseTenants            LeaseTenant[]
  leaseUnits              LeaseUnit[]
  products                Product[]
  purchaseOrders          PurchaseOrder[]
  services                Service[]
  staff                   Staff[]
  students                Student[]
  homeworkAssignments     HomeworkAssignment[]
  teachingLogs            TeachingLog[]
  exams                   Exam[]
  taxRates                TaxRate[]
  transactions            Transaction[]
  users                   User[]
  vendors                 Vendor[]
  whatsappMessages        WhatsAppMessage[]
  assetCategories         AssetCategory[]
  assets                  Asset[]
  attendanceLogs          AttendanceLog[]
  subscriptions           CustomerSubscription[]
  membershipPlans         MembershipPlan[]
  campaigns               WhatsAppCampaign[]
  vendorBills             VendorBill[]
  vendorProducts          VendorProduct[]
  goodsReceiptNotes       GoodsReceiptNote[]
  bankAccounts            BankAccount[]
  creditNotes             CreditNote[]
  quotations              Quotation[]
  payrollRuns             PayrollRun[]
  recurringInvoices       RecurringInvoice[]
  roleRequests            RoleRequest[]
  supportTickets          SupportTicket[]
  exercises               Exercise[]
  workoutTemplates        WorkoutTemplate[]
  memberPlans             MemberPlan[]
  bodyStats               MemberBodyStats[]
  trainerNotes            TrainerNote[]
  complianceRecord        ComplianceRecord?
  tenantNotes             TenantNote[]
  displayCatalog          DisplayCatalogItem[]   @relation("DisplayCatalog")
  sentPartnerRequests     BusinessPartnership[]  @relation("PartnerSentRequests")
  receivedPartnerRequests BusinessPartnership[]  @relation("PartnerReceivedRequests")
  buyerNegotiations       PriceNegotiation[]     @relation("NegotiationBuyer")
  supplierNegotiations    PriceNegotiation[]     @relation("NegotiationSupplier")
  ratingsGiven            BusinessRating[]       @relation("RatingsGiven")
  ratingsReceived         BusinessRating[]       @relation("RatingsReceived")
  saleReturns             SaleReturn[]
  roles                   Role[]
  branches                Branch[]
  branchStocks            BranchStock[]
  stockTransfers          StockTransfer[]
  auditReports            AuditReport[]

  hasBranches             Boolean                @default(false)
  featureConfigs          TenantFeatureConfig[]

  @@map("tenants")
}

model User {
  id                  String    @id @default(uuid())
  tenantId            String
  name                String
  email               String
  password            String
  role                UserRole  @default(STAFF)
  branchId            String?
  permissionProfile   String?
  customPermissions   Json?
  roleId              String?
  assignedRole        Role?     @relation(fields: [roleId], references: [id], onDelete: SetNull)
  branch              Branch?   @relation(fields: [branchId], references: [id])
  language            String    @default("en")
  isActive            Boolean   @default(true)
  isEmailVerified     Boolean   @default(false)
  emailVerifyToken    String?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  syllabrixId         String?   @unique
  refreshToken        String?
  lastLogin           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  color       String?
  isSystem    Boolean  @default(false)
  isOwner     Boolean  @default(false)
  templateKey String?
  permissions Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Customer {
  id                String                 @id @default(uuid())
  tenantId          String
  name              String
  phone             String?
  email             String?
  address           String?
  gstin             String?
  notes             String?
  totalSpent        Float                  @default(0)
  creditBalance     Float                  @default(0)
  creditLimit       Float                  @default(0)
  birthday          DateTime?
  loyaltyPoints     Int                    @default(0)
  visitCount        Int                    @default(0)
  lastVisitAt       DateTime?
  tags              String[]
  gymMembershipId   String?
  personalTrainerId String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  appointments      Appointment[]
  tenant            Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices          Invoice[]
  transactions      Transaction[]
  subscriptions     CustomerSubscription[]
  creditNotes       CreditNote[]
  quotations        Quotation[]
  recurringInvoices RecurringInvoice[]
  saleReturns       SaleReturn[]
  memberPlans       MemberPlan[]
  bodyStats         MemberBodyStats[]
  trainerNotes      TrainerNote[]

  @@map("customers")
}

model Staff {
  id               String          @id @default(uuid())
  tenantId         String
  branchId         String?
  name             String
  phone            String?
  email            String?
  role             String
  department       String?
  salary           Float?
  joinedAt         DateTime?
  biometricId      String?
  isActive         Boolean         @default(true)
  specialization   String[]
  bio              String?
  certifications   String[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  appointments     Appointment[]
  attendanceLogs   AttendanceLog[]
  payrollEntries   PayrollEntry[]
  workoutTemplates     WorkoutTemplate[]
  memberPlansAsTrainer MemberPlan[]      @relation("MemberPlanTrainer")
  trainerNotes         TrainerNote[]
  tenant               Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch               Branch?           @relation(fields: [branchId], references: [id])

  @@index([tenantId, branchId])
  @@map("staff")
}

model Category {
  id          String     @id @default(uuid())
  tenantId    String
  name        String
  description String?
  parentId    String?
  isStandard  Boolean    @default(false)
  sortOrder   Int        @default(0)
  color       String?
  icon        String?
  code        String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products    Product[]

  @@map("categories")
}

model Product {
  id               String            @id @default(uuid())
  tenantId         String
  categoryId       String?
  name             String
  description      String?
  sku              String?
  barcode          String?
  unit             String            @default("pcs")
  costPrice        Float             @default(0)
  sellingPrice     Float
  mrp              Float?
  hsnCode          String?
  taxRateId        String?
  stock            Float             @default(0)
  lowStockAlert    Float             @default(5)
  batchNumber      String?
  expiryDate       DateTime?
  imageUrl         String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  invoiceItems     InvoiceItem[]
  purchaseItems    PurchaseItem[]
  grnLines         GRNLine[]
  vendorProducts   VendorProduct[]
  category         Category?         @relation(fields: [categoryId], references: [id])
  taxRate          TaxRate?          @relation(fields: [taxRateId], references: [id])
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stockMovements     StockMovement[]
  transactionItems   TransactionItem[]
  branchStocks       BranchStock[]
  transferItems      StockTransferItem[]

  @@unique([tenantId, sku])
  @@map("products")
}

model TaxRate {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  rate      Float
  isGst     Boolean   @default(true)
  cgst      Float?
  sgst      Float?
  igst      Float?
  createdAt DateTime  @default(now())
  products  Product[]
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tax_rates")
}

model StockMovement {
  id          String            @id @default(uuid())
  tenantId    String
  productId   String
  type        StockMovementType
  quantity    Float
  beforeStock Float
  afterStock  Float
  reference   String?
  notes       String?
  createdAt   DateTime          @default(now())
  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}

model Transaction {
  id             String            @id @default(uuid())
  tenantId       String
  branchId       String?
  customerId     String?
  invoiceId      String?           @unique
  receiptNumber  String            @unique
  subtotal       Float
  discountAmount Float             @default(0)
  taxAmount      Float             @default(0)
  total          Float
  amountPaid     Float
  change         Float             @default(0)
  paymentMethod  PaymentMethod     @default(CASH)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  items          TransactionItem[]
  customer       Customer?         @relation(fields: [customerId], references: [id])
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch?           @relation(fields: [branchId], references: [id])
  saleReturns    SaleReturn[]

  @@index([tenantId, branchId])
  @@map("transactions")
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String
  productId     String
  name          String
  hsnCode       String?
  quantity      Float
  unitPrice     Float
  discount      Float       @default(0)
  gstRate       Float       @default(0)
  taxAmount     Float       @default(0)
  cgst          Float       @default(0)
  sgst          Float       @default(0)
  igst          Float       @default(0)
  total         Float
  product       Product     @relation(fields: [productId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("transaction_items")
}

model Invoice {
  id                 String        @id @default(uuid())
  tenantId           String
  branchId           String?
  customerId         String?
  invoiceNumber      String        @unique
  status             InvoiceStatus @default(DRAFT)
  issueDate          DateTime      @default(now())
  dueDate            DateTime?
  subtotal           Float
  discountAmount     Float         @default(0)
  taxAmount          Float         @default(0)
  total              Float
  amountPaid         Float         @default(0)
  balanceDue         Float
  notes              String?
  terms              String?
  gstDetails         Json?
  razorpayLinkId     String?
  razorpayLinkUrl    String?
  razorpayLinkStatus String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  items              InvoiceItem[]
  customer           Customer?     @relation(fields: [customerId], references: [id])
  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch             Branch?       @relation(fields: [branchId], references: [id])
  payments           Payment[]
  creditNotes        CreditNote[]
  saleReturns        SaleReturn[]

  @@index([tenantId, branchId])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Float
  unitPrice   Float
  discount    Float    @default(0)
  taxRate     Float    @default(0)
  taxAmount   Float    @default(0)
  total       Float
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}

model Payment {
  id        String        @id @default(uuid())
  invoiceId String
  amount    Float
  method    PaymentMethod
  reference String?
  notes     String?
  paidAt    DateTime      @default(now())
  invoice   Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Service {
  id           String        @id @default(uuid())
  tenantId     String
  name         String
  description  String?
  duration     Int
  price        Float
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("services")
}

model Appointment {
  id         String            @id @default(uuid())
  tenantId   String
  customerId String?
  staffId    String?
  serviceId  String?
  title      String
  notes      String?
  status     AppointmentStatus @default(SCHEDULED)
  startTime  DateTime
  endTime    DateTime
  price      Float?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  customer   Customer?         @relation(fields: [customerId], references: [id])
  service    Service?          @relation(fields: [serviceId], references: [id])
  staff      Staff?            @relation(fields: [staffId], references: [id])
  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("appointments")
}

model Student {
  id                  String               @id @default(uuid())
  tenantId            String
  name                String
  phone               String?
  email               String?
  parentName          String?
  parentPhone         String?
  course              String?
  batch               String?
  enrolledAt          DateTime             @default(now())
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  feeRecords          FeeRecord[]
  homeworkSubmissions HomeworkSubmission[]
  examPreps           ExamStudentPrep[]
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("students")
}

// ─── Progress & Homework ──────────────────────────────────────────────────────

model HomeworkAssignment {
  id          String               @id @default(uuid())
  tenantId    String
  subject     String
  description String
  classGroup  String
  dueDate     DateTime
  createdAt   DateTime             @default(now())
  submissions HomeworkSubmission[]
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, dueDate])
  @@map("homework_assignments")
}

model HomeworkSubmission {
  id         String             @id @default(uuid())
  tenantId   String
  homeworkId String
  studentId  String
  status     String             @default("PENDING")
  notes      String?
  updatedAt  DateTime           @updatedAt
  homework   HomeworkAssignment @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student    Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([homeworkId, studentId])
  @@map("homework_submissions")
}

model TeachingLog {
  id         String   @id @default(uuid())
  tenantId   String
  subject    String
  topic      String
  classGroup String
  notes      String?
  taughtDate DateTime @default(now())
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, taughtDate])
  @@map("teaching_logs")
}

model Exam {
  id           String            @id @default(uuid())
  tenantId     String
  title        String
  subject      String
  examType     String            @default("UNIT_TEST")
  classGroup   String            @default("")
  examDate     DateTime
  totalMarks   Int?
  topics       Json              @default("[]")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  studentPreps ExamStudentPrep[]
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, examDate])
  @@map("exams")
}

model ExamStudentPrep {
  id            String   @id @default(uuid())
  examId        String
  studentId     String
  tenantId      String
  readiness     Int      @default(0)
  weakTopics    Json     @default("[]")
  notes         String?
  marksObtained Float?
  grade         String?
  updatedAt     DateTime @updatedAt
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@map("exam_student_preps")
}

model FeeRecord {
  id            String         @id @default(uuid())
  tenantId      String
  studentId     String
  description   String
  amount        Float
  discount      Float          @default(0)
  netAmount     Float
  dueDate       DateTime
  status        FeeStatus      @default(PENDING)
  paidAmount    Float          @default(0)
  paidAt        DateTime?
  paymentMethod PaymentMethod?
  receiptNumber String?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  student       Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("fee_records")
}

model LeaseUnit {
  id          String        @id @default(uuid())
  tenantId    String
  unitNumber  String
  floor       String?
  area        Float?
  description String?
  isOccupied  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  leases      LeaseTenant[]
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, unitNumber])
  @@map("lease_units")
}

model LeaseTenant {
  id           String      @id @default(uuid())
  tenantId     String
  unitId       String
  businessName String
  contactName  String?
  phone        String?
  email        String?
  monthlyRent  Float
  deposit      Float       @default(0)
  startDate    DateTime
  endDate      DateTime?
  status       LeaseStatus @default(ACTIVE)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit         LeaseUnit   @relation(fields: [unitId], references: [id])

  @@map("lease_tenants")
}

enum BusinessType {
  // ── Existing ─────────────────────────────────────────────────────────────
  RETAIL
  KIRANA
  COACHING
  SALON
  CLINIC
  RESTAURANT
  GYM
  MALL
  FREELANCER
  WORKSHOP
  OTHER

  // ── Retail & Commerce ────────────────────────────────────────────────────
  MEDICAL_STORE
  STATIONARY
  SWEET_SHOP
  BAKERY
  JEWELLERY
  HARDWARE
  ELECTRICAL
  CLOTHING
  FOOTWEAR
  ELECTRONICS
  MOBILE_REPAIR
  OPTICAL
  BOOKSTORE
  FLORIST

  // ── Food & Beverage ──────────────────────────────────────────────────────
  DHABA
  CATERING
  CLOUD_KITCHEN
  JUICE_BAR
  CANTEEN_MESS

  // ── Events & Functions ───────────────────────────────────────────────────
  EVENT_PLANNER
  DECORATOR
  TENT_HOUSE

  // ── Healthcare ───────────────────────────────────────────────────────────
  DENTAL
  DIAGNOSTIC_LAB
  PHYSIOTHERAPY
  AYURVEDA
  HOSPITAL
  VET_CLINIC

  // ── Beauty & Personal Care ───────────────────────────────────────────────
  BEAUTY_PARLOUR
  SPA
  LAUNDRY
  TAILORING
  BARBERSHOP

  // ── Education ────────────────────────────────────────────────────────────
  HOME_TUITION
  MUSIC_SCHOOL
  DANCE_ACADEMY
  DRIVING_SCHOOL
  COMPUTER_TRAINING

  // ── Professional Services ────────────────────────────────────────────────
  CA_FIRM
  LAW_FIRM
  REAL_ESTATE
  INSURANCE_AGENCY
  TRAVEL_AGENCY
  PHOTOGRAPHY
  DIGITAL_AGENCY

  // ── Transport & Logistics ────────────────────────────────────────────────
  CAB_SERVICE
  TRANSPORT
  CAR_RENTAL
  COURIER
  PACKERS_MOVERS

  // ── Construction & Design ────────────────────────────────────────────────
  CONSTRUCTION
  INTERIOR_DESIGN
  CO_WORKING

  // ── Trade & Supply (B2B) ─────────────────────────────────────────────────
  DEALER
  SUPPLIER
  WHOLESALE

  // ── Fitness & Sports ─────────────────────────────────────────────────────
  YOGA_STUDIO
  MARTIAL_ARTS
  SPORTS_ACADEMY
  SWIMMING_ACADEMY
  CROSSFIT_STUDIO

  // ── Other Services ───────────────────────────────────────────────────────
  PEST_CONTROL
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  ACCOUNTANT
  CASHIER
  STAFF
}

enum PlanType {
  STARTER
  GROWTH
  SCALE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  CHEQUE
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum FeeStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  WAIVED
}

enum LeaseStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  PENDING
}

enum StockMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
  DAMAGE
}

// ─── Vendors / Suppliers ──────────────────────────────────────────────────────

model Vendor {
  id             String          @id @default(uuid())
  tenantId       String
  name           String
  contactPerson  String?
  phone          String?
  email          String?
  address        String?
  gstin          String?
  paymentTerms   String?
  notes          String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  purchaseOrders PurchaseOrder[]
  bills          VendorBill[]
  catalog        VendorProduct[]

  @@map("vendors")
}

// Items a vendor can supply — their catalog / price list
model VendorProduct {
  id          String   @id @default(uuid())
  tenantId    String
  vendorId    String
  productId   String? // optional link to our inventory product
  itemName    String
  vendorSku   String?
  vendorPrice Float    @default(0)
  minOrderQty Float    @default(1)
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@map("vendor_products")
}

model PurchaseOrder {
  id           String              @id @default(uuid())
  tenantId     String
  branchId     String?
  vendorId     String?
  poNumber     String
  status       PurchaseOrderStatus @default(DRAFT)
  orderDate    DateTime            @default(now())
  expectedDate DateTime?
  receivedDate DateTime?
  subtotal     Float               @default(0)
  taxAmount    Float               @default(0)
  total        Float               @default(0)
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  branch       Branch?             @relation(fields: [branchId], references: [id])
  vendor       Vendor?             @relation(fields: [vendorId], references: [id])
  items        PurchaseItem[]
  grns         GoodsReceiptNote[]

  @@index([tenantId, branchId])
  @@map("purchase_orders")
}

model PurchaseItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String?
  description     String
  quantity        Float
  unitCost        Float
  taxRate         Float         @default(0)
  taxAmount       Float         @default(0)
  total           Float
  receivedQty     Float         @default(0)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
