// ═══════════════════════════════════════════════════════════════════════════
// SYLLABRIX PLATFORM LAYER — Super Admin, Support, Compliance, Announcements
// ═══════════════════════════════════════════════════════════════════════════

model SuperAdmin {
  id             String         @id @default(uuid())
  name           String
  email          String         @unique
  password       String
  role           SuperAdminRole @default(SUPPORT)
  platformRoleId String?
  isActive       Boolean        @default(true)
  lastLogin      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  platformRole   PlatformRole?            @relation(fields: [platformRoleId], references: [id])
  grantsReceived PlatformPermissionGrant[] @relation("GrantRecipient")
  grantsGiven    PlatformPermissionGrant[] @relation("GrantGiver")

  @@map("super_admins")
}

enum SuperAdminRole {
  SUPER
  ADMIN
  SUPPORT
  COMPLIANCE
  ANALYST
  DEVELOPER
}

model PlatformRole {
  id          String      @id @default(uuid())
  name        String      @unique
  label       String
  description String?
  isBuiltIn   Boolean     @default(false)
  permissions Json
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  admins      SuperAdmin[]

  @@map("platform_roles")
}

model PlatformPermissionGrant {
  id          String    @id @default(uuid())
  adminId     String
  wing        String
  access      String[]
  grantedById String
  reason      String
  expiresAt   DateTime?
  revokedAt   DateTime?
  revokedById String?
  createdAt   DateTime  @default(now())

  admin       SuperAdmin @relation("GrantRecipient", fields: [adminId],     references: [id], onDelete: Cascade)
  grantedBy   SuperAdmin @relation("GrantGiver",     fields: [grantedById], references: [id])

  @@index([adminId])
  @@map("platform_permission_grants")
}

model SupportTicket {
