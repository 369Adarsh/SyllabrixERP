// Public-facing product catalog a supplier/dealer shares with connected buyers
model DisplayCatalogItem {
  id               String             @id @default(uuid())
  supplierTenantId String
  productName      String
  description      String?
  sku              String?
  unit             String             @default("pcs")
  basePrice        Float
  moq              Float              @default(1)
  maxOrderQty      Float?
  hsnCode          String?
  taxRate          Float              @default(0)
  category         String?
  imageUrl         String?
  isAvailable      Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  supplierTenant   Tenant             @relation("DisplayCatalog", fields: [supplierTenantId], references: [id], onDelete: Cascade)
  negotiations     PriceNegotiation[]

  @@index([supplierTenantId, isAvailable])
  @@map("display_catalog_items")
}

// Cross-tenant buyer ↔ supplier connection
model BusinessPartnership {
  id                String             @id @default(uuid())
  requesterTenantId String
  supplierTenantId  String
  status            PartnershipStatus  @default(PENDING)
  message           String?
  requestedAt       DateTime           @default(now())
  respondedAt       DateTime?
  // Payment terms agreed between the two parties
  paymentTerms      PaymentTerms       @default(COD)
  creditDays        Int?               // for NET_X terms
  advancePct        Int?               // % advance for ADVANCE_PARTIAL
  creditLimit       Float?             // max outstanding credit extended
  termsNotes        String?            // free-text custom terms
  requester         Tenant             @relation("PartnerSentRequests", fields: [requesterTenantId], references: [id], onDelete: Cascade)
  supplier          Tenant             @relation("PartnerReceivedRequests", fields: [supplierTenantId], references: [id], onDelete: Cascade)
  negotiations      PriceNegotiation[]
  ratings           BusinessRating[]

  @@unique([requesterTenantId, supplierTenantId])
  @@map("business_partnerships")
}

// Buyer requests a better price for a specific catalog item
model PriceNegotiation {
  id               String              @id @default(uuid())
  partnershipId    String
  catalogItemId    String
  buyerTenantId    String
  supplierTenantId String
  requestedQty     Float
  buyerTargetPrice Float
  status           NegotiationStatus   @default(PENDING)
  finalPrice       Float?
  notes            String?
  expiresAt        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  partnership      BusinessPartnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
  catalogItem      DisplayCatalogItem  @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  buyerTenant      Tenant              @relation("NegotiationBuyer", fields: [buyerTenantId], references: [id])
  supplierTenant   Tenant              @relation("NegotiationSupplier", fields: [supplierTenantId], references: [id])
  rounds           NegotiationRound[]

  @@index([buyerTenantId, status])
  @@index([supplierTenantId, status])
  @@map("price_negotiations")
}

// Each offer/counter-offer round in a negotiation
model NegotiationRound {
  id            String           @id @default(uuid())
  negotiationId String
  offeredBy     String
  price         Float
  qty           Float?
  message       String?
  createdAt     DateTime         @default(now())
  negotiation   PriceNegotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)

  @@map("negotiation_rounds")
}

// Verified buyer rates a supplier after doing business
model BusinessRating {
  id                  String               @id @default(uuid())
  reviewerTenantId    String
  targetTenantId      String
  partnershipId       String?
  overallRating       Int                  // 1–5 stars (required)
  qualityRating       Int?                 // Product quality
  deliveryRating      Int?                 // On-time delivery
  communicationRating Int?                 // Responsiveness
  paymentRating       Int?                 // Payment compliance
  review              String?              // Optional written review
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  reviewer            Tenant               @relation("RatingsGiven",    fields: [reviewerTenantId], references: [id], onDelete: Cascade)
  target              Tenant               @relation("RatingsReceived", fields: [targetTenantId],   references: [id], onDelete: Cascade)
  partnership         BusinessPartnership? @relation(fields: [partnershipId], references: [id], onDelete: SetNull)

  @@unique([reviewerTenantId, targetTenantId])
  @@index([targetTenantId])
  @@map("business_ratings")
}

enum PaymentTerms {
  ADVANCE_FULL     // 100% payment before dispatch
  ADVANCE_PARTIAL  // Partial % advance (see advancePct)
  COD              // Cash / payment on delivery
  NET_15           // Invoice due in 15 days
  NET_30           // Invoice due in 30 days
  NET_45           // Invoice due in 45 days
  NET_60           // Invoice due in 60 days
  LETTER_OF_CREDIT // Bank-backed LC
  CUSTOM           // Free-text terms (see termsNotes)
}

enum PartnershipStatus {
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

enum NegotiationStatus {
  PENDING
  COUNTERED
  ACCEPTED
  REJECTED
  EXPIRED
  PO_CREATED
}

// ─── Training Plans (Gym / Fitness) ──────────────────────────────────────────

model Exercise {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  category     String
  muscleGroup  String
  equipment    String?
  description  String?
  instructions String?
  difficulty   String   @default("Beginner")
  defaultSets  Int?
  defaultReps  String?
  imageUrl     String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templateExercises WorkoutTemplateExercise[]

  @@index([tenantId])
  @@map("exercises")
}

model WorkoutTemplate {
  id            String   @id @default(uuid())
  tenantId      String
  trainerId     String
  name          String
  description   String?
  goal          String
  level         String
  durationWeeks Int      @default(4)
  daysPerWeek   Int      @default(3)
  isPublic      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trainer       Staff    @relation(fields: [trainerId], references: [id])
  days          WorkoutTemplateDay[]
  memberPlans   MemberPlan[]

  @@index([tenantId, trainerId])
  @@map("workout_templates")
}

model WorkoutTemplateDay {
  id         String          @id @default(uuid())
  templateId String
  template   WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  dayNumber  Int
  label      String
  isRestDay  Boolean         @default(false)
  exercises  WorkoutTemplateExercise[]

  @@map("workout_template_days")
}

model WorkoutTemplateExercise {
  id          String             @id @default(uuid())
  dayId       String
  day         WorkoutTemplateDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exerciseId  String
  exercise    Exercise           @relation(fields: [exerciseId], references: [id])
  order       Int                @default(0)
  sets        Int?               @default(3)
  reps        String?
  duration    String?
  restSeconds Int?               @default(60)
  weight      String?
  notes       String?

  @@map("workout_template_exercises")
}

model MemberPlan {
  id         String          @id @default(uuid())
  tenantId   String
  memberId   String
  templateId String
  trainerId  String
  startDate  DateTime
  endDate    DateTime?
  status     String          @default("ACTIVE")
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member     Customer        @relation(fields: [memberId], references: [id])
  template   WorkoutTemplate @relation(fields: [templateId], references: [id])
  trainer    Staff           @relation("MemberPlanTrainer", fields: [trainerId], references: [id])
  sessions   WorkoutSession[]

  @@index([tenantId, trainerId])
  @@index([tenantId, memberId])
  @@map("member_plans")
}

model WorkoutSession {
  id        String     @id @default(uuid())
  planId    String
  plan      MemberPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  date      DateTime   @default(now())
  dayNumber Int
  completed Boolean    @default(false)
  duration  Int?
  notes     String?
  logs      WorkoutSessionLog[]
  createdAt DateTime   @default(now())

  @@index([planId])
  @@map("workout_sessions")
}

model WorkoutSessionLog {
  id         String         @id @default(uuid())
  sessionId  String
  session    WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId String
  sets       Int?
  reps       String?
  weight     String?
  notes      String?

  @@map("workout_session_logs")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  actorType  String
  actorId    String
  actorName  String
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Member Body Stats & Trainer Notes ───────────────────────────────────────

model MemberBodyStats {
  id         String   @id @default(uuid())
  tenantId   String
  memberId   String
  weight     Float?
  height     Float?
  bodyFat    Float?
  chest      Float?
  waist      Float?
  hips       Float?
  notes      String?
  recordedAt DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member     Customer @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([tenantId, memberId])
  @@map("member_body_stats")
}

model TrainerNote {
  id        String   @id @default(uuid())
  tenantId  String
  memberId  String
  trainerId String
  content   String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member    Customer @relation(fields: [memberId], references: [id], onDelete: Cascade)
  trainer   Staff    @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([tenantId, memberId])
  @@map("trainer_notes")
}

// ─── Returns / Refunds ────────────────────────────────────────────────────────

enum ReturnRefundMethod {
  CASH
  UPI
  BANK_TRANSFER
  STORE_CREDIT
  EXCHANGE
}

model SaleReturn {
  id            String             @id @default(uuid())
  tenantId      String
  branchId      String?
  returnNumber  String             @unique
  sourceType    String             // 'INVOICE' | 'TRANSACTION'
  invoiceId     String?
  transactionId String?
  customerId    String?
  reason        String
  refundMethod  ReturnRefundMethod @default(CASH)
  refundAmount  Float
  notes         String?
  createdAt     DateTime           @default(now())
  items         SaleReturnItem[]
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch?            @relation(fields: [branchId], references: [id])
  invoice       Invoice?           @relation(fields: [invoiceId], references: [id])
  transaction   Transaction?       @relation(fields: [transactionId], references: [id])
  customer      Customer?          @relation(fields: [customerId], references: [id])

  @@index([tenantId, branchId])
  @@map("sale_returns")
}

model SaleReturnItem {
  id          String     @id @default(uuid())
  returnId    String
  productId   String?
  description String
  quantity    Float
  unitPrice   Float
  total       Float
  saleReturn  SaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@map("sale_return_items")
}

// ─── Multi-Branch ─────────────────────────────────────────────────────────────

model Branch {
  id           String    @id @default(uuid())
  tenantId     String
  syllabrixId  String?   @unique
  name         String
  code         String    // short code e.g. "MKT", "STN", "NCL", "RLY"
  address      String?
  city         String?
  phone        String?
  gstin        String?
  managerId    String?   // userId of the branch manager
  isHQ         Boolean   @default(false)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff             Staff[]
  users             User[]
  transactions      Transaction[]
  invoices          Invoice[]
  expenses          Expense[]
  assets            Asset[]
  quotations        Quotation[]
  saleReturns       SaleReturn[]
  branchStocks      BranchStock[]
  transfersFrom     StockTransfer[]    @relation("TransferFrom")
  transfersTo       StockTransfer[]    @relation("TransferTo")
  purchaseOrders    PurchaseOrder[]
  goodsReceiptNotes GoodsReceiptNote[]
  vendorBills       VendorBill[]
  featureConfigs    BranchFeatureConfig[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("branches")
}

model BranchStock {
  id        String   @id @default(uuid())
  tenantId  String
  branchId  String
  productId String
  quantity  Float    @default(0)
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([branchId, productId])
  @@index([tenantId])
  @@map("branch_stock")
}

model StockTransfer {
  id             String               @id @default(uuid())
  tenantId       String
  transferNumber String               @unique
  fromBranchId   String
  toBranchId     String
  status         StockTransferStatus  @default(REQUESTED)
  requestedById  String?
  approvedById   String?
  notes          String?
  isEmergency    Boolean              @default(false)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromBranch Branch              @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranch   Branch              @relation("TransferTo", fields: [toBranchId], references: [id])
  items      StockTransferItem[]

  @@index([tenantId, status])
  @@map("stock_transfers")
}

model StockTransferItem {
  id         String        @id @default(uuid())
  transferId String
  productId  String
  quantity   Float
  unitCost   Float         @default(0)

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product       @relation(fields: [productId], references: [id])

  @@map("stock_transfer_items")
}

enum StockTransferStatus {
  REQUESTED
  APPROVED
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

// ─── Precision Diagnostic System ──────────────────────────────────────────────

model AuditReport {
  id          String        @id @default(uuid())
  reportId    String        @unique                // RPT-YYMMDD-NNN
  tenantId    String
  pageRoute   String                               // e.g. "/reports"
  modules     String[]                             // moduleKey[] audited
  errorDesc   String
  frequency   String        @default("SOMETIMES")  // FIRST_TIME | SOMETIMES | ALWAYS
  auditResult Json?                                // last AI audit JSON
  dedupHash   String                               // hash for clustering duplicates
  occurrences Int           @default(1)
  priority    AuditPriority @default(P2)
  status      AuditStatus   @default(SUBMITTED)
  reporterName String?
  reporterRole String?
  assignedTo  String?
  resolvedAt  DateTime?
  fixNotes    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([dedupHash])
  @@map("audit_reports")
}

enum AuditPriority {
  P1
  P2
  P3
}

enum AuditStatus {
  SUBMITTED
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ─── Platform Error Logs ──────────────────────────────────────────────────────

model PlatformErrorLog {
  id         String   @id @default(uuid())
  tenantId   String?
  method     String
  path       String
  statusCode Int
  message    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([statusCode, createdAt])
  @@index([tenantId, createdAt])
  @@index([createdAt])
  @@map("platform_error_logs")
}

// ─── Feature Flags ────────────────────────────────────────────────────────────

model FeatureFlag {
  id        String   @id @default(uuid())
  moduleKey String   @unique
  isEnabled Boolean  @default(true)
  reason    String?
  toggledBy String?
  toggledAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("feature_flags")
}

// ─── Business Activity Log ────────────────────────────────────────────────────

model TenantActivityLog {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String
  userName     String
  userRole     String
  action       String   // e.g. INVOICE_CREATED, FEE_COLLECTED, LOGIN
  module       String   // invoicing | fees | inventory | pos | appointments | expenses | customers | auth | staff
  resourceType String?  // Invoice | FeeRecord | Product | Appointment …
  resourceId   String?
  details      Json?
  ipAddress    String?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, module])
  @@index([tenantId, createdAt])
  @@index([createdAt])
  @@map("tenant_activity_logs")
}

// ─── Maintenance Windows ──────────────────────────────────────────────────────

model MaintenanceWindow {
  id          String    @id @default(uuid())
  title       String
  message     String
  startAt     DateTime
  endAt       DateTime
  isActive    Boolean   @default(false)
  isEmergency Boolean   @default(false)
  createdBy   String
  createdAt   DateTime  @default(now())
  cancelledAt DateTime?

  @@index([isActive])
  @@index([startAt])
  @@map("maintenance_windows")
}

// ─── Business Builder ─────────────────────────────────────────────────────────
// NOTE: Model is named BusinessTypeConfig (not BusinessType) to avoid conflict
// with the existing BusinessType enum. Rename to BusinessType once enum is removed (Week 5).

model BusinessCategory {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique // "SYL-BC-PAC"
  icon        String?
  description String?
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())

  businessTypes BusinessTypeConfig[]

  @@map("business_categories")
}

model BusinessTypeConfig {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique // "SYL-BC-PAC-PS01"
  enumKey     String?   @unique // original enum value e.g. "GYM" (nullable for new types)
  categoryId  String
  icon        String?
  description String?
  isActive    Boolean   @default(false)
  isTemplate  Boolean   @default(false)
  createdBy   String
  createdAt   DateTime  @default(now())
  publishedAt DateTime?

  category  BusinessCategory      @relation(fields: [categoryId], references: [id])
  modules   BusinessTypeModule[]
  roles     BusinessTypeRole[]
  templates BusinessTemplate[]

  @@index([categoryId])
  @@index([isActive])
  @@map("business_type_configs")
}

model BusinessTypeModule {
  id             String             @id @default(cuid())
  businessTypeId String
  moduleKey      String
  tier           String             @default("CORE") // CORE | OPTIONAL | LOCKED
  planRequired   String?
  sortOrder      Int                @default(0)

  businessType   BusinessTypeConfig @relation(fields: [businessTypeId], references: [id], onDelete: Cascade)

  @@unique([businessTypeId, moduleKey])
  @@map("business_type_modules")
}

model BusinessTypeRole {
  id             String             @id @default(cuid())
  businessTypeId String
  roleName       String
  permissions    Json
  isDefault      Boolean            @default(true)

  businessType   BusinessTypeConfig @relation(fields: [businessTypeId], references: [id], onDelete: Cascade)

  @@map("business_type_roles")
}

model BusinessTemplate {
  id             String              @id @default(cuid())
  name           String
  description    String?
  modules        Json
  businessTypeId String?
  createdBy      String
  createdAt      DateTime            @default(now())

  businessType   BusinessTypeConfig? @relation(fields: [businessTypeId], references: [id])

  @@map("business_templates")
}

// ─── Platform Plans & Offers ──────────────────────────────────────────────────

model PlatformPlan {
  id           String   @id @default(uuid())
  key          String   @unique // STARTER | GROWTH | SCALE
  name         String
  tagline      String?
  description  String?
  monthlyPrice Float
  yearlyPrice  Float?
  color        String   @default("#1FB8D6")
  isActive     Boolean  @default(true)
  isPublic     Boolean  @default(true)
  trialDays    Int      @default(0)
  modules      Json     // String[] of module keys included
  maxUsers     Int?
  maxBranches  Int?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("platform_plans")
}

model PlatformOffer {
  id              String    @id @default(uuid())
  code            String    @unique
  description     String?
  discountType    String    // PERCENT | FLAT
  discountValue   Float
  applicablePlans Json      // String[] of plan keys
  maxUses         Int?
  usedCount       Int       @default(0)
  validFrom       DateTime?
  validUntil      DateTime?
  isActive        Boolean   @default(true)
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("platform_offers")
}

// ─── Module Feature Management ────────────────────────────────────────────────
// Platform defines every possible feature per module.
// Plans unlock feature tiers. Tenants set company defaults. Branches override.

model ModuleFeature {
  id           String   @id @default(uuid())
  moduleKey    String   // e.g. "SYL-MOD-POS", "SYL-MOD-INV"
  featureKey   String   @unique // e.g. "pos.barcode_scanner"
  name         String
  description  String?
  tier         String   @default("BASIC") // BASIC | STANDARD | ADVANCED | ENTERPRISE
  defaultOn    Boolean  @default(true)    // default when plan unlocks this tier
  dependencies String[] // featureKey[] that must be ON for this to work
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)   // platform can globally disable
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantConfigs TenantFeatureConfig[]
  branchConfigs BranchFeatureConfig[]

  @@index([moduleKey])
  @@map("module_features")
}

model TenantFeatureConfig {
  id         String   @id @default(uuid())
  tenantId   String
  featureKey String
  enabled    Boolean  @default(true)
  enforced   Boolean  @default(false) // if true, branches cannot override
  updatedAt  DateTime @updatedAt

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  feature ModuleFeature @relation(fields: [featureKey], references: [featureKey], onDelete: Cascade)

  @@unique([tenantId, featureKey])
  @@index([tenantId])
  @@map("tenant_feature_configs")
}

model BranchFeatureConfig {
  id         String   @id @default(uuid())
  branchId   String
  tenantId   String
  featureKey String
  enabled    Boolean  @default(true)
  updatedAt  DateTime @updatedAt

  branch  Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  feature ModuleFeature @relation(fields: [featureKey], references: [featureKey], onDelete: Cascade)

  @@unique([branchId, featureKey])
  @@index([branchId])
  @@index([tenantId])
  @@map("branch_feature_configs")
}

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("platform_settings")
}
