{
  "name": "syllabrix-backend",
  "version": "1.0.0",
  "description": "Syllabrix ERP — Node.js + Express + PostgreSQL backend",
  "main": "src/server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon src/server.js",
    "dev:quality": "cross-env NODE_ENV=quality nodemon src/server.js",
    "start": "cross-env NODE_ENV=production node src/server.js",
    "start:quality": "cross-env NODE_ENV=quality node src/server.js",
    "db:push": "cross-env NODE_ENV=development npx prisma db push",
    "db:push:quality": "cross-env NODE_ENV=quality npx prisma db push",
    "db:push:prod": "cross-env NODE_ENV=production npx prisma db push",
    "db:studio": "cross-env NODE_ENV=development npx prisma studio",
    "db:studio:quality": "cross-env NODE_ENV=quality npx prisma studio",
    "db:generate": "prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "prisma": "^5.22.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.14"
  }
}
