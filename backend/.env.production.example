# ─── Syllabrix Production Environment ────────────────────────────────────────
# Copy this to .env.production and fill in all values before deploying.
# NEVER commit .env.production to git.

NODE_ENV=production

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Database (Supabase production project) ───────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# ─── JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ──
# Minimum 32 characters. Use different values for each secret.
JWT_SECRET=
JWT_REFRESH_SECRET=
SA_JWT_SECRET=

# ─── JWT Expiry ───────────────────────────────────────────────────────────────
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Frontend URL (CORS whitelist) ────────────────────────────────────────────
# Comma-separated if multiple domains: https://app.syllabrix.in,https://www.syllabrix.in
CLIENT_URL=https://app.syllabrix.in

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
FROM_EMAIL=noreply@syllabrix.in

# ─── AI (Google Gemini) ───────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── WhatsApp (Meta Business API) ────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_WABA_ID=
# Webhook verify token AND HMAC secret — set a strong random string (min 32 chars)
WHATSAPP_WEBHOOK_SECRET=

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret from Razorpay Dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=
