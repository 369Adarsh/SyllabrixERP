# ── Database ───────────────────────────────────────────
# Get this from Railway (PostgreSQL plugin) or Supabase
DATABASE_URL="postgresql://user:password@host:5432/syllabrix"

# ── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── JWT ────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (Nodemailer) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@syllabrix.com

# ── AI (Claude API) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
