# ── Database ───────────────────────────────────────────
# Get this from Railway (PostgreSQL plugin) or Supabase
DATABASE_URL="postgresql://user:password@host:5432/syllabrix"

# ── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── JWT ────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (Nodemailer via Gmail) ───────────────────────
# 1. Enable 2FA on your Google account
# 2. Go to Google Account → Security → App Passwords
# 3. Generate a password for "Mail" → paste it as EMAIL_PASS
# If not set, reset links are logged to the backend console (dev mode)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-16-char-app-password
FRONTEND_URL=http://localhost:5173

# ── AI (Claude API) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Razorpay (UPI payment links on invoices) ───────────
# 1. Sign up at razorpay.com → Dashboard → API Keys
# 2. Use Test keys for development, Live keys for production
# 3. For webhook: Dashboard → Webhooks → Add URL: https://yourdomain/api/v1/webhooks/razorpay
#    Select event: payment_link.paid
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
